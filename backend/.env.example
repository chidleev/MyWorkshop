PORT=3000
DB_URL=mysql://my_workshop_user:my_workshop_password@localhost:3306/my_workshop
DB_CONNECT_TIMEOUT_MS=10000

# Optional fallback if DB_URL is not set.
DB_HOST=localhost
DB_PORT=3306
DB_USER=my_workshop_user
DB_PASSWORD=my_workshop_password
DB_NAME=my_workshop

# Single origin or comma-separated list of origins.
# Examples:
# FRONTEND_URL=https://myworkshop.example.com
# FRONTEND_URLS=http://localhost:5173,https://myworkshop.example.com
FRONTEND_URL=https://myworkshop.example.com
FRONTEND_URLS=
CRM_API_URL=
USE_MOCK_CRM=true
EXTERNAL_API_KEY=changeme

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@myworkshop.local
